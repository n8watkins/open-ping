{
  "name": "open-ping",
  "version": "0.1.0",
  "description": "Open-source, self-hosted uptime monitoring and public status page running entirely in your own Cloudflare account.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/secure-build-output.mjs",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc -b",
    "lint": "tsc -b",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "db:create": "wrangler d1 create open-ping",
    "db:migrate:local": "wrangler d1 migrations apply open-ping --local",
    "db:migrate": "wrangler d1 migrations apply open-ping --remote"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "hono": "^4.6.14",
    "lucide-react": "^0.469.0",
    "luxon": "^3.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10",
    "wrangler": "^4.106.0"
  }
}
